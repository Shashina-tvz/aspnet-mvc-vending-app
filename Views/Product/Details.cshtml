@model VendingMachineApp.Data.Entities.Product
@{
    ViewData["Title"] = "Product Details";
    Layout = "../Shared/_Layout.cshtml";
}
<style>
    .details-panel {
        background: #23272f;
        color: #f3f3f3;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.10);
        padding: 2.5rem 2.5rem 2rem 2.5rem;
        max-width: 540px;
        margin: 2rem auto;
    }
    .details-section { margin-bottom: 1.5rem; }
    .details-label { color: #b0b3b8; font-size: 0.98rem; margin-bottom: 0.2rem; }
    .details-value { font-size: 1.1rem; font-weight: 500; margin-bottom: 0.7rem; }
    .back-link { color: #4fc3f7; text-decoration: none; font-weight: 500; }
    .back-link:hover { text-decoration: underline; }
</style>
<div class="details-panel">
    <h2 style="margin-bottom:1.5rem;">Product Details</h2>
    <div class="details-section">
        <div class="details-label">Name</div>
        <div class="details-value">@Model.Name</div>
    </div>
    <div class="details-section">
        <div class="details-label">Category</div>
        <div class="details-value">@Model.Category</div>
    </div>
    <div class="details-section">
        <div class="details-label">Price</div>
        <div class="details-value">@Model.Price.ToString("C")</div>
    </div>
    <div class="details-section">
        <div class="details-label">Supplier ID</div>
        <div class="details-value">@Model.SupplierId</div>
    </div>
    <div class="details-section">
        <div class="details-label">Description</div>
        <div class="details-value">@Model.Description</div>
    </div>
    <div class="details-section">
        <div class="details-label">Manufacture Date</div>
        <div class="details-value">@Model.ManufactureDate.ToShortDateString()</div>
    </div>
    <div class="details-section">
        <div class="details-label">Expiration Date</div>
        <div class="details-value">@Model.ExpirationDate.ToShortDateString()</div>
    </div>
    <div class="details-section">
        <div class="details-label">Reorder Threshold</div>
        <div class="details-value">@Model.ReorderThreshold</div>
    </div>
    <a class="back-link" href="/Product/Index">&#8592; Back to List</a>
</div>
