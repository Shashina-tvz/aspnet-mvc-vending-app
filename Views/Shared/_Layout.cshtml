@using VendingMachineApp.Data.Repositories
@inject MockProductRepository productRepo
@inject MockSupplierRepository supplierRepo
@inject VendingMachineApp.Data.Repositories.MockVendingMachineRepository machineRepo
@inject VendingMachineApp.Data.Repositories.MockOrderRepository orderRepo
@inject VendingMachineApp.Data.Repositories.MockMaintenanceLogRepository logRepo
@inject VendingMachineApp.Data.Repositories.MockTechnicianRepository techRepo

@{
    var products = productRepo.GetAll().ToList();
    var suppliers = supplierRepo.GetAll().ToList();
   var machines = machineRepo.GetAll().ToList();
    var orders = orderRepo.GetAll().ToList();
    var logs = logRepo.GetAll().ToList();
    var technicians = techRepo.GetAll().ToList();
}


<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - VendingMachineApp</title>

```

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #1b1e24;
        color: #f3f3f3;
        display: flex;
    }

    /* SIDEBAR */
    .sidebar {
        width: 240px;
        background: #23272f;
        height: 100vh;
        padding: 1.5rem;
        box-sizing: border-box;
        position: fixed;
    }

    .sidebar h2 {
        color: #4fc3f7;
        margin-bottom: 2rem;
    }

    .nav-link {
        display: block;
        color: #f3f3f3;
        text-decoration: none;
        padding: 10px 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        transition: 0.2s;
    }

    .nav-link:hover {
        background: #2e323a;
    }

    /* CONTENT */
    .content {
        margin-left: 240px;
        padding: 2rem;
        width: 100%;
    }

    /* FLYOUT MENU */
    .nav-item {
        position: relative;
    }

    .flyout {
        position: absolute;
        left: 100%;
        top: 0;

        background: #23272f;
        border-radius: 10px;
        padding: 10px;

        display: none;
        flex-direction: column;

        min-width: 220px;
        max-height: 300px;
        overflow-y: auto;

        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .flyout a {
        color: #b0b3b8;
        text-decoration: none;
        padding: 8px 10px;
        border-radius: 6px;
    }

    .flyout a:hover {
        background: #2e323a;
        color: white;
    }

    .nav-item:hover .flyout {
        display: flex;
    }

    /* SCROLLBAR */
    .flyout::-webkit-scrollbar {
        width: 6px;
    }

    .flyout::-webkit-scrollbar-thumb {
        background: #4fc3f7;
        border-radius: 10px;
    }
</style>
```

</head>

<body>

```
<div class="sidebar">
    <h2>Vending App</h2>

    <a class="nav-link" href="/Dashboard">Dashboard</a>

    <!-- PRODUCTS -->
    <div class="nav-item">
        <a class="nav-link" href="/Product">Products</a>

        <div class="flyout">
            @foreach (var p in products)
            {
                <a href="/Product/Details/@p.ProductId">@p.Name</a>
            }
        </div>
    </div>

    <!-- SUPPLIERS -->
    <div class="nav-item">
        <a class="nav-link" href="/Supplier">Suppliers</a>

        <div class="flyout">
            @foreach (var s in suppliers)
            {
                <a href="/Supplier/Details/@s.SupplierId">@s.Name</a>
            }
        </div>
    </div>

 <!-- VENDING MACHINES -->
   <div class="nav-item">
    <a class="nav-link" href="/VendingMachine">Machines</a>

    <div class="flyout">
        @foreach (var m in machines)
        {
            <a href="/VendingMachine/Details/@m.MachineId">Machine @m.MachineNumber</a>
        }
    </div>
</div>

<!-- ORDERS -->
    <div class="nav-item">
    <a class="nav-link" href="/Order">Orders</a>

    <div class="flyout">
        @foreach (var o in orders)
        {
            <a href="/Order/Details/@o.OrderId">Order #@o.OrderId</a>
        }
    </div>
</div>

<!-- MAINTENANCE LOGS -->
    <div class="nav-item">
    <a class="nav-link" href="/MaintenanceLog">Maintenance</a>

    <div class="flyout">
        @foreach (var l in logs)
        {
            <a href="/MaintenanceLog/Details/@l.MaintenanceLogId">
                @l.Status - @l.MaintenanceDate.ToShortDateString()
            </a>
        }
    </div>
</div>

<!-- TECHNICIANS -->
    <div class="nav-item">
    <a class="nav-link" href="/Technician">Technicians</a>

    <div class="flyout">
        @foreach (var t in technicians)
        {
            <a href="/Technician/Details/@t.TechnicianId">@t.Name</a>
        }
    </div>
</div>
</div>

<div class="content">
    @RenderBody()
</div>
```

</body>
</html>

