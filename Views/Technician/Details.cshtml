@model VendingMachineApp.Data.Entities.Technician

@{
    ViewData["Title"] = "Technician Details";
    Layout = "../Shared/_Layout.cshtml";
}

<style>
    .details-panel {
        background: #23272f;
        color: #f3f3f3;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.10);
        padding: 2.5rem;
        max-width: 540px;
        margin: 2rem auto;
    }

    .details-section { margin-bottom: 1.5rem; }
    .details-label { color: #b0b3b8; font-size: 0.98rem; margin-bottom: 0.2rem; }
    .details-value { font-size: 1.1rem; font-weight: 500; margin-bottom: 0.7rem; }
</style>

<div class="details-panel">
    <h2 style="margin-bottom:1.5rem;">Technician Details</h2>

    <div class="details-section">
        <div class="details-label">Name</div>
        <div class="details-value">@Model.Name</div>
    </div>

    <div class="details-section">
        <div class="details-label">License Number</div>
        <div class="details-value">@Model.LicenseNumber</div>
    </div>

    <div class="details-section">
        <div class="details-label">Email</div>
        <div class="details-value">@Model.Email</div>
    </div>

    <div class="details-section">
        <div class="details-label">Phone</div>
        <div class="details-value">@Model.PhoneNumber</div>
    </div>

    <div class="details-section">
        <div class="details-label">Hire Date</div>
        <div class="details-value">@Model.HireDate.ToString("dd.MM.yyyy")</div>
    </div>

    <div class="details-section">
        <div class="details-label">Maintenance Logs</div>
        <div class="details-value">
            @(Model.MaintenanceLogs?.Count ?? 0)
        </div>
    </div>

    <a class="back-link" href="/Technician/Index">&#8592; Back to List</a>
</div>